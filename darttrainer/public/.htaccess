# Laravel maršrutam `/` jāiet caur index.php; public/index.html tikai novirza uz `/` (Vite SPA).
DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Vite assets
    RewriteRule ^build/ - [L]

    # Static files
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # API -> index.php
    RewriteRule ^ index.php [L]
</IfModule>
