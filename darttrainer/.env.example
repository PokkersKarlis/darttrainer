APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost
# Optional: shown in admin panel "build" block (e.g. git tag or deploy id)
APP_VERSION=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# lax (default) helps mitigate CSRF; use strict if the SPA is always same-site; production HTTPS: SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
# SESSION_SECURE_COOKIE=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Novirzījums pēc e-pasta apstiprināšanas (SPA ar hash router). Noklusējums: APP_URL. Rezerve: ${APP_URL}/index.html
FRONTEND_URL="${APP_URL}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Vite HMR (izstrāde bez «npm run build» katru reizi) ---
# Palaid Vite: Docker → make up-dev vai make up-all | lokāli → npm run dev
# .env (kopē no šī piemēra):
#   APP_URL=http://localhost:8088
#   VITE_DEV_SERVER_URL=http://localhost:5173
# Ja pārlūkā lieto 127.0.0.1, liec to pašu APP_URL un VITE hostā (vai visur localhost).
# Produkcijā: VITE_DEV_SERVER_URL neieraksta — tad tiek lietots npm run build + manifest.
#
# npm vienreiz: docker compose --profile tools run --rm nodejs npm … | make npm-install
#
# Ātrākā HMR uz Windows: `npm run dev` uz hosta (ne Docker), tāpat VITE_DEV_SERVER_URL — izvairās no bind mount I/O.
